# Experiment 2-1: Prompt Engineering on a single-card Ascend server.
# Copy to configs/exp2_1.env. Change WORK_ROOT only when your server uses another data disk.

RUN_MODE=smoke
WORK_ROOT=/home/ma-user/work/openpangu_lab
OUTPUT_ROOT=${WORK_ROOT}/outputs/exp2_1
HF_ENDPOINT=https://hf-mirror.com

# User-level environment bootstrap. CANN/driver must already exist in the server image.
AUTO_SETUP_ENV=1
PYTHON_BIN=python3.10
CONDA_ENV_NAME=
VENV_DIR=${WORK_ROOT}/.venv
VENV_SYSTEM_SITE_PACKAGES=1
ASCEND_TOOLKIT_ENV=/usr/local/Ascend/ascend-toolkit/set_env.sh
SETUPTOOLS_INSTALL_COMMAND="python -m pip install setuptools==69.5.1"

# Leave these empty when the server image already provides compatible torch and torch_npu.
TORCH_INSTALL_COMMAND=
TORCH_NPU_INSTALL_COMMAND=

# openPangu model for inference.
MODEL_PATH=${WORK_ROOT}/models/openPangu-Embedded-7B-V1.1
MODEL_DOWNLOAD_GUARD=${MODEL_PATH}/config.json
MODEL_DOWNLOAD_COMMAND="python -m pip install huggingface_hub && python -m src.common.download_hf FreedomIntelligence/openPangu-Embedded-7B-V1.1 ${WORK_ROOT}/models/openPangu-Embedded-7B-V1.1"

MAX_INPUT_LENGTH=8192
MAX_NEW_TOKENS=512

# Keep empty for this assignment; the notebook's after-class LLM-as-Judge part is not required.
JUDGE_API_BASE=
JUDGE_API_KEY=
JUDGE_MODEL=

SKIP_PIP_INSTALL=0
