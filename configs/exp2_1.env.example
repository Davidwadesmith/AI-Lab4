# Experiment 2-1: Prompt Engineering on single-card Ascend 910B.
RUN_MODE=smoke
OUTPUT_ROOT=outputs/exp2_1

# One-click environment bootstrap.
# System-level Ascend driver/CANN must already be installed by the server image/admin.
AUTO_SETUP_ENV=1
PYTHON_BIN=python3.10
CONDA_ENV_NAME=
VENV_DIR=.venv
ASCEND_TOOLKIT_ENV=/usr/local/Ascend/ascend-toolkit/set_env.sh
SETUPTOOLS_INSTALL_COMMAND=
NINJA_INSTALL_COMMAND=
NINJA_TARGET_DIR=

# Use commands that match your server image and torch-npu/CANN version.
# Leave empty if the image already has matching torch and torch_npu.
TORCH_INSTALL_COMMAND=
TORCH_NPU_INSTALL_COMMAND=

# Set this on the inference server.
MODEL_PATH=/path/to/openPangu-Embedded-7B-V1.1
MODEL_DOWNLOAD_COMMAND=

MAX_INPUT_LENGTH=8192
MAX_NEW_TOKENS=2048

# Set to 1 if server packages are already installed.
SKIP_PIP_INSTALL=0

# Optional OpenAI-compatible judge API. Leave empty to skip LLM-as-Judge.
JUDGE_API_BASE=
JUDGE_API_KEY=
JUDGE_MODEL=
