# Experiment 2-2 shared-environment template for /src/init/Shared.
# Copy this file to configs/exp2_2.env and replace USER_ROOT with your own directory.

RUN_MODE=smoke
USER_ROOT=/src/init/09024126hcc
SHARED_ROOT=/src/init/Shared
OUTPUT_ROOT=/src/init/09024126hcc/outputs/exp2_2

AUTO_SETUP_ENV=1
PYTHON_BIN=python3.10
CONDA_ENV_NAME=
VENV_DIR=/src/init/09024126hcc/.venv
ASCEND_TOOLKIT_ENV=/usr/local/Ascend/ascend-toolkit/set_env.sh
SETUPTOOLS_INSTALL_COMMAND="python -m pip install setuptools==69.5.1"
NINJA_INSTALL_COMMAND=
NINJA_TARGET_DIR=/src/init/09024126hcc/python_pkgs

# Leave empty when the server image already has compatible torch/torch_npu.
TORCH_INSTALL_COMMAND=
TORCH_NPU_INSTALL_COMMAND=

# Shared read-only resources.
MINDSPEED_LLM_ROOT=/src/init/Shared/MindSpeed-LLM
AUTO_CLONE_MINDSPEED=0
MINDSPEED_LLM_REPO=
MINDSPEED_LLM_REF=
INSTALL_MINDSPEED=0

HF_MODEL_PATH=/src/init/Shared/openPangu-Embedded-7B-V1.1
TOKENIZER_MODEL=/src/init/Shared/openPangu-Embedded-7B-V1.1
MODEL_DOWNLOAD_COMMAND=

# Fill the exact JSONL filename from /src/init/Shared/data.
SOURCE_JSONL=/src/init/Shared/data/chinese_deepseek_r1_distill.jsonl
SOURCE_DATASET_PATH=
SOURCE_DATASET_SPLIT=train
DATA_DOWNLOAD_COMMAND=

# Personal writable outputs. Do not write conversion/export/checkpoints into Shared.
MCORE_MODEL_PATH=/src/init/09024126hcc/ckpts/openPangu_7B_mcore
SFT_HF_OUTPUT_PATH=/src/init/09024126hcc/hf_export/openPangu_sft_hf
DATA_CACHE_PREFIX=/src/init/09024126hcc/cache/finetune_pangu7b_xhs_seqlen8k/sft

ASCEND_RT_VISIBLE_DEVICES=0,1,2,3
NPUS_PER_NODE=4
MASTER_PORT=6000

SEQ_LENGTH=8192
PREPROCESS_WORKERS=4

# Space-saving course settings.
TRAIN_ITERS=100
SAVE_INTERVAL=100
LR_WARMUP_ITERS=20
NO_SAVE_OPTIM=1
LEARNING_RATES=1e-5,5e-6,6e-7
GLOBAL_BATCH_SIZES=4

FORCE_PREPROCESS=0
FORCE_CONVERT=0
EXPORT_HF=1
DRY_RUN=0
SKIP_PIP_INSTALL=0
