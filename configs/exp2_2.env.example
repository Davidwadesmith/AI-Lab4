# Experiment 2-2: openPangu-7B SFT on a four-card Ascend server.
# Copy to configs/exp2_2.env. Change WORK_ROOT only when your server uses another data disk.

RUN_MODE=smoke
WORK_ROOT=/home/ma-user/work/openpangu_lab
OUTPUT_ROOT=${WORK_ROOT}/outputs/exp2_2
HF_ENDPOINT=https://hf-mirror.com

# User-level environment bootstrap. CANN/driver must already exist in the server image.
AUTO_SETUP_ENV=1
PYTHON_BIN=python3.10
CONDA_ENV_NAME=
VENV_DIR=${WORK_ROOT}/.venv
VENV_SYSTEM_SITE_PACKAGES=1
ASCEND_TOOLKIT_ENV=/usr/local/Ascend/ascend-toolkit/set_env.sh
SETUPTOOLS_INSTALL_COMMAND="python -m pip install setuptools==69.5.1"
NINJA_INSTALL_COMMAND=
NINJA_TARGET_DIR=${WORK_ROOT}/python_pkgs

# Leave these empty when the server image already provides compatible torch and torch_npu.
TORCH_INSTALL_COMMAND=
TORCH_NPU_INSTALL_COMMAND=

# MindSpeed-LLM code. Use a fixed commit/branch if your course server requires one.
MINDSPEED_LLM_ROOT=${WORK_ROOT}/MindSpeed-LLM
AUTO_CLONE_MINDSPEED=1
MINDSPEED_LLM_REPO=https://github.com/Ascend/MindSpeed-LLM.git
MINDSPEED_LLM_REF=
INSTALL_MINDSPEED=1
PYTHONPATH_EXTRA=/usr/local/python3.10/lib/python3.10/site-packages/torch_npu/dynamo:${MINDSPEED_LLM_ROOT}/MindSpeed/build/lib:${MINDSPEED_LLM_ROOT}

# openPangu base checkpoint and tokenizer.
HF_MODEL_PATH=${WORK_ROOT}/models/openPangu-Embedded-7B-V1.1
TOKENIZER_MODEL=${WORK_ROOT}/models/openPangu-Embedded-7B-V1.1
MODEL_DOWNLOAD_GUARD=${HF_MODEL_PATH}/config.json
MODEL_DOWNLOAD_COMMAND="python -m pip install huggingface_hub && python -m src.common.download_hf FreedomIntelligence/openPangu-Embedded-7B-V1.1 ${WORK_ROOT}/models/openPangu-Embedded-7B-V1.1"

# Notebook dataset: use streaming and keep only enough xhs/xhs samples for the assignment run.
SOURCE_JSONL=
SOURCE_DATASET_PATH=Congliu/Chinese-DeepSeek-R1-Distill-data-110k-SFT
SOURCE_DATASET_SPLIT=train
SOURCE_DATASET_STREAMING=1
MAX_TRAIN_RECORDS=2000
DATA_DOWNLOAD_COMMAND=

# Personal writable outputs.
MCORE_MODEL_PATH=${WORK_ROOT}/ckpts/openPangu_7B_mcore
SFT_HF_OUTPUT_PATH=${WORK_ROOT}/hf_export/openPangu_sft_hf
DATA_CACHE_PREFIX=${WORK_ROOT}/cache/finetune_pangu7b_xhs_seqlen8k/sft

ASCEND_RT_VISIBLE_DEVICES=0,1,2,3
NPUS_PER_NODE=4
MASTER_PORT=6000

SEQ_LENGTH=8192
PREPROCESS_WORKERS=4

# Space-saving homework settings.
TRAIN_ITERS=100
SAVE_INTERVAL=100
LR_WARMUP_ITERS=20
NO_SAVE_OPTIM=1
LEARNING_RATES=5e-5
GLOBAL_BATCH_SIZES=4

FORCE_PREPROCESS=0
FORCE_CONVERT=0
EXPORT_HF=1
DRY_RUN=0
SKIP_PIP_INSTALL=0
