# Experiment 2-2: MindSpeed-LLM SFT on four-card Ascend 910B.
RUN_MODE=smoke
OUTPUT_ROOT=outputs/exp2_2

# MindSpeed-LLM repository on the training server.
MINDSPEED_LLM_ROOT=/home/ma-user/work/MindSpeed-LLM

# Source data. Prefer SOURCE_JSONL when you have already exported raw records.
# SOURCE_DATASET_PATH supports the notebook style: datasets.load_dataset(path).
SOURCE_JSONL=/path/to/chinese_deepseek_r1_distill.jsonl
SOURCE_DATASET_PATH=
SOURCE_DATASET_SPLIT=train

# openPangu-7B Hugging Face checkpoint and tokenizer paths.
HF_MODEL_PATH=/path/to/openPangu_7B_hf
TOKENIZER_MODEL=/path/to/openPangu_7B_hf

# mcore checkpoint path used as SFT starting point.
MCORE_MODEL_PATH=/cache/ckpts/openPangu_7B_mcore
SFT_HF_OUTPUT_PATH=/cache/sft_outputs/openPangu_7B_sft_hf

ASCEND_RT_VISIBLE_DEVICES=0,1,2,3
NPUS_PER_NODE=4
MASTER_PORT=6000

SEQ_LENGTH=8192
PREPROCESS_WORKERS=4
DATA_CACHE_PREFIX=/cache/finetune_pangu7b_xhs_seqlen8k/sft

TRAIN_ITERS=3200
LEARNING_RATES=1e-5,5e-6,6e-7
GLOBAL_BATCH_SIZES=1,2,4

# Idempotency controls.
FORCE_PREPROCESS=0
FORCE_CONVERT=0
EXPORT_HF=0
DRY_RUN=0
SKIP_PIP_INSTALL=0
INSTALL_MINDSPEED=1
